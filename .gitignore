## .NET gitignore

# Build output
[Bb]in/
[Oo]bj/

# Visual Studio files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
*.snupkg
.nuget/

# Rider
.idea/

# VS Code
.vscode/

# User secrets (never commit these)
secrets.json
appsettings.*.local.json

# SQLite database files (regenerated by migrations)
*.db
*.db-shm
*.db-wal

# OS generated
.DS_Store
Thumbs.db

# Test results
TestResults/
coverage/
*.trx
*.coveragexml
